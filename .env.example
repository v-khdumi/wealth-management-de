# Azure OpenAI Configuration
# When these variables are set the application routes AI requests to Azure OpenAI.
# When they are absent it falls back to the GitHub Spark LLM runtime.

VITE_AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
VITE_AZURE_OPENAI_API_KEY=<your-api-key>
VITE_AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Deployment names (must match deployments created in Azure AI Foundry)
VITE_AZURE_OPENAI_DEPLOYMENT_GPT4O_MINI=gpt-4o-mini
VITE_AZURE_OPENAI_DEPLOYMENT_GPT4O=gpt-4o
